# ToneShift Environment Variables Template
# Copy this file to a new file named '.env' in the same directory and fill in your keys.

# Google Gemini API Key - Get yours from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend host and port (defaults to 127.0.0.1:8000)
HOST=127.0.0.1
PORT=8000
